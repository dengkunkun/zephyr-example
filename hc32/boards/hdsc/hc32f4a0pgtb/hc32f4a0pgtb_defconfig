# Clocks and GPIO
CONFIG_CLOCK_CONTROL=y
CONFIG_GPIO=y
CONFIG_PINCTRL=y

# Serial / console
CONFIG_SERIAL=y
CONFIG_CONSOLE=y
CONFIG_UART_CONSOLE=y

# MPU off for the initial bring-up (FMR_CC main.c uses extensive
# peripheral register access; enable later once drivers stabilise)
CONFIG_ARM_MPU=n
CONFIG_HW_STACK_PROTECTION=n
